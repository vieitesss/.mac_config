# config-file = keybinds
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 0s

# font
font-family = Terminess Nerd Font Mono
font-size = 19
font-thicken = true
# window-inherit-font-size = false

# window
# macos-titlebar-style = hidden
mouse-hide-while-typing = true
# window-save-state = always

background-opacity = 0.9

# theme
# theme = Teerb
# theme = mellifluous
# theme = ashen
# theme = rose-pine
theme = umbraline

# keybinds
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6
keybind = alt+7=goto_tab:7
keybind = alt+8=goto_tab:8

config-file = "vim.ghostty"
